rules_version = '2';

// Säkerhetsregler för Tipspromenaden.
//
// Modell:
//   walks/{walkId}                            – publik läsning, ägaren skriver
//   sessions/{sessionId}                      – publik läsning, vem som helst
//                                               inloggad kan skapa, statusen
//                                               kan flyttas (waiting -> active
//                                               -> completed) av vem som helst
//                                               inloggad. Ingen radering.
//   sessions/{sessionId}/participants/{uid}   – varje deltagare får bara skriva
//                                               sin egen post (dok-id måste
//                                               matcha auth.uid). Publik
//                                               läsning för topplistan.
//
// Allmänna principer:
//   - Skapare: Google-inloggade (firebase-auth provider != 'anonymous').
//   - Deltagare: anonyma (`signInAnonymously`).
//   - Walks och sessions är publika data — vem som helst med QR-länken kan
//     se dem. Det är meningen.
//   - Poäng beräknas fortfarande klientside; reglerna förhindrar bara att
//     en deltagare manipulerar någon annans deltagardokument.

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------- users --------------------
    // Privata kontodokument — endast ägaren. Används för taggar som
    // följer kontot (users/{uid}/meta/walkTags), framtida preferenser
    // etc. Firestore ger inbyggd 1 MB-gräns per dokument; övriga
    // storleksgränser hanteras i klienten.
    match /users/{uid}/meta/{docId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Hämtar walks/{walkId} och kontrollerar att inloggad user är ägare.
    // Måste deklareras inuti service-scopet eftersom den använder $(database).
    function isWalkOwner(walkId) {
      return walkId is string
             && exists(/databases/$(database)/documents/walks/$(walkId))
             && get(/databases/$(database)/documents/walks/$(walkId)).data.createdBy
                == request.auth.uid;
    }

    function sessionStatus(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)).data.status;
    }

    // -------------------- walks --------------------
    match /walks/{walkId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && !isAnonymous()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.id == walkId
                    && hasValidWalkShape(request.resource.data);

      allow update: if isSignedIn()
                    && resource.data.createdBy == request.auth.uid
                    && request.resource.data.createdBy == resource.data.createdBy
                    && request.resource.data.id == walkId
                    && hasValidWalkShape(request.resource.data);

      allow delete: if isSignedIn()
                    && resource.data.createdBy == request.auth.uid;
    }

    // -------------------- sessions --------------------
    match /sessions/{sessionId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.id == sessionId
                    && request.resource.data.walkId is string
                    && request.resource.data.status in ['waiting', 'active']
                    // Sessionen måste peka på en faktisk walk — blockerar att
                    // någon spammar sessioner mot påhittade walkId:n.
                    && exists(/databases/$(database)/documents/walks/$(request.resource.data.walkId));

      // Tillåt bara att uppdatera `status`. Dessutom: bara framåtriktade
      // övergångar (waiting -> active -> completed). Detta hindrar att någon
      // återuppväcker ett avslutat spel eller rullar tillbaka statusen.
      // Fältet får inte sättas till oväntade värden.
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status'])
                    && isForwardStatusTransition(resource.data.status,
                                                 request.resource.data.status);

      // Endast ägaren av promenaden får radera sessionen (för konto-radering /
      // GDPR-rensning).
      allow delete: if isSignedIn()
                    && isWalkOwner(resource.data.walkId);

      // -------- participants subcollection --------
      match /participants/{participantId} {
        allow read: if true;

        // Doc-id MÅSTE matcha auth.uid. Det är den centrala spärren mot att
        // manipulera andras poäng. Score får inte vara större än antalet svar
        // — detta stoppar trivial inflation; full validering mot facit kräver
        // Cloud Functions (se roadmap). Tak på answers.size() (300) hindrar
        // att någon inflaterar svarslistan med tomma objekt för att blåsa
        // upp score utan tak.
        //
        // Sessionen får inte vara `completed` — efter avslutat spel ska
        // topplistan vara fryst.
        allow create: if isSignedIn()
                      && request.auth.uid == participantId
                      && request.resource.data.id == participantId
                      && hasValidParticipantShape(request.resource.data)
                      && sessionStatus(sessionId) != 'completed';

        allow update: if isSignedIn()
                      && request.auth.uid == participantId
                      && request.resource.data.id == participantId
                      && hasValidParticipantShape(request.resource.data)
                      && sessionStatus(sessionId) != 'completed';

        // Deltagaren får radera sin egen post (GDPR), och promenadens ägare
        // får radera när de raderar konto/promenad.
        allow delete: if isSignedIn()
                      && (request.auth.uid == participantId
                          || isWalkOwner(get(/databases/$(database)/documents/sessions/$(sessionId)).data.walkId));
      }
    }

    // -------------------- tipspacks --------------------
    // Användar-uppladdade .tipspack-filer (frågebatterier) som kan delas
    // via tipspromenaden.app/tipspack. Doc-id == slug (genereras från
    // filnamnet av klienten). Storage-fil ligger på
    // `tipspack/{slug}.tipspack` och vidhängs en metadata-doc här som
    // /tipspack-listan kan visa utan att ladda hela JSON-filen.
    //
    // Två synlighetsnivåer:
    //   isPublic: true   → visas i bibliotekets listsida, vem som helst
    //                       med direkt URL kan ladda ner
    //   isPublic: false  → INTE i listan ("hemlig länk") — vem som helst
    //                       med direkt URL kan fortfarande ladda ner.
    //                       Storage-filen är publikt läsbar oavsett.
    //
    // Skapare måste vara icke-anonym. Slug-uniqueness säkerställs via
    // doc-id (Firestore tillåter inte två dokument med samma id).
    match /tipspacks/{slug} {
      allow read: if true;

      allow create: if isSignedIn()
                    && !isAnonymous()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.slug == slug
                    && hasValidTipspackShape(request.resource.data);

      allow update: if isSignedIn()
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.ownerUid == resource.data.ownerUid
                    && request.resource.data.slug == slug
                    && hasValidTipspackShape(request.resource.data);

      allow delete: if isSignedIn()
                    && resource.data.ownerUid == request.auth.uid;
    }
  }
}

// -------------------- helpers --------------------

function isSignedIn() {
  return request.auth != null;
}

function isAnonymous() {
  return request.auth != null
         && request.auth.token.firebase.sign_in_provider == 'anonymous';
}

// Sessionsstatus får bara röra sig framåt: waiting -> active -> completed.
// Oförändrad status är också tillåten (t.ex. när andra fält... fast update-
// reglen tillåter bara diff på 'status', så samma-till-samma är en no-op).
function isForwardStatusTransition(from, to) {
  return (from == 'waiting'   && to in ['waiting', 'active', 'completed'])
      || (from == 'active'    && to in ['active', 'completed'])
      || (from == 'completed' && to == 'completed');
}

function hasValidTipspackShape(data) {
  return data.slug is string
         && data.slug.matches('^[a-z0-9_-]+$')
         && data.slug.size() > 0
         && data.slug.size() <= 100
         && data.ownerUid is string
         && data.name is string
         && data.name.size() > 0
         && data.name.size() <= 200
         && data.questionCount is number
         && data.questionCount > 0
         && data.questionCount <= 500
         && data.isPublic is bool
         && data.createdAt is number
         && (!('description' in data)
             || (data.description is string && data.description.size() <= 2000))
         && (!('author' in data)
             || (data.author is string && data.author.size() <= 200))
         && (!('language' in data)
             || (data.language is string && data.language.size() <= 10))
         && (!('fileSizeBytes' in data)
             || (data.fileSizeBytes is number && data.fileSizeBytes <= 5 * 1024 * 1024))
         && (!('ownerName' in data)
             || (data.ownerName is string && data.ownerName.size() <= 100));
}

function hasValidWalkShape(data) {
  return data.id is string
         && data.title is string
         && data.title.size() > 0
         && data.title.size() <= 200
         && data.createdBy is string
         && data.createdAt is number
         && data.questions is list
         && data.questions.size() <= 200
         && (!('description' in data)
             || (data.description is string && data.description.size() <= 2000));
}

// Validerar deltagardokument. Namn-regex blockerar HTML/script-tecken så att
// rendering i WebView/Leaflet aldrig kan bli en XSS-yta. answers tak är 300
// (= 200 frågor i walk + marginal). score måste vara <= answers.size().
function hasValidParticipantShape(data) {
  return data.name is string
         && data.name.size() > 0
         && data.name.size() <= 60
         && !data.name.matches('.*[<>"\'`].*')
         && data.score is number
         && data.score >= 0
         && data.answers is list
         && data.answers.size() <= 300
         && data.score <= data.answers.size();
}

// (isWalkOwner är deklarerad inuti service-scopet ovan eftersom den behöver
// $(database). Att lägga den här ute ger CompilerWarning W eftersom $(database)
// inte är i scope.)
