rules_version = '2';

// Säkerhetsregler för Firebase Storage.
//
// Modell:
//   walks/{walkId}/questions/{questionId}.jpg  – bilder kopplade till
//     en specifik fråga i en promenad. Endast skaparen (walk.createdBy)
//     får skriva/radera; alla får läsa.
//
// Begränsningar:
//   - max 2 MB per fil
//   - endast image/*
//   - skribent måste matcha walks/{walkId}.createdBy i Firestore om
//     dokumentet finns. Om dokumentet INTE finns än (vanligt under
//     create-flödet eftersom walken sparas först när användaren
//     trycker "Spara") tillåts vilken signed-in icke-anonym
//     användare som helst — walkId är 96-bit crypto-random så
//     ID-kollisioner är försumbara, och bilden blir ändå "föräldralös"
//     om walken aldrig sparas (eller sparas av annan användare).

service firebase.storage {
  match /b/{bucket}/o {
    // -------------------- tipspacks --------------------
    // Användar-uppladdade .tipspack-filer. Path: tipspack/<slug> (utan
    // extension i path:en — Content-Disposition på objektet sätter
    // download-namnet till <slug>.tipspack).
    //
    // Slug-uniqueness säkerställs via Firestore-doc-id (tipspacks/<slug>).
    // Owner-check görs mot Firestore-doc:s ownerUid-fält.
    //
    // Klient-flöde: skapa Firestore-doc FÖRST → ladda upp till Storage.
    // Om Storage failar raderar klienten Firestore-doc:en (rollback).
    //
    // Read är publikt — "hemlig länk" är obscurity, inte auth.
    match /tipspack/{slug} {
      allow read: if true;

      allow write: if request.auth != null
                   && request.auth.token.firebase.sign_in_provider != 'anonymous'
                   && request.resource.size < 5 * 1024 * 1024
                   && (
                        !firestore.exists(/databases/(default)/documents/tipspacks/$(slug))
                        || firestore.get(/databases/(default)/documents/tipspacks/$(slug)).data.ownerUid == request.auth.uid
                      );

      allow delete: if request.auth != null
                    && request.auth.token.firebase.sign_in_provider != 'anonymous'
                    && (
                         !firestore.exists(/databases/(default)/documents/tipspacks/$(slug))
                         || firestore.get(/databases/(default)/documents/tipspacks/$(slug)).data.ownerUid == request.auth.uid
                       );
    }

    match /walks/{walkId}/questions/{imageName} {
      allow read: if true;

      allow write: if request.auth != null
                   && request.auth.token.firebase.sign_in_provider != 'anonymous'
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && (
                        !firestore.exists(/databases/(default)/documents/walks/$(walkId))
                        || firestore.get(/databases/(default)/documents/walks/$(walkId)).data.createdBy == request.auth.uid
                      );

      allow delete: if request.auth != null
                    && request.auth.token.firebase.sign_in_provider != 'anonymous'
                    && (
                         !firestore.exists(/databases/(default)/documents/walks/$(walkId))
                         || firestore.get(/databases/(default)/documents/walks/$(walkId)).data.createdBy == request.auth.uid
                       );
    }
  }
}
