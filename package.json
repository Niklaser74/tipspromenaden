{
  "name": "tipspromenaden-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "strip-readonly": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/strip-readonly.ps1",
    "build:preview": "npm run strip-readonly && eas build -p android --profile preview",
    "build:internal": "npm run strip-readonly && eas build -p android --profile internal",
    "build:production": "npm run strip-readonly && eas build -p android --profile production",
    "update:preview": "eas update --channel preview",
    "update:internal": "eas update --channel internal",
    "update:production": "eas update --channel production",
    "update:all": "node scripts/update-all.mjs"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.7",
    "@react-navigation/material-top-tabs": "^7.4.23",
    "@react-navigation/native": "^7.2.0",
    "@react-navigation/native-stack": "^7.14.7",
    "expo": "~55.0.8",
    "expo-auth-session": "~55.0.9",
    "expo-camera": "~55.0.10",
    "expo-crypto": "~55.0.10",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.11",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.18",
    "expo-localization": "~55.0.13",
    "expo-location": "~55.1.4",
    "expo-screen-orientation": "~55.0.13",
    "expo-sensors": "~55.0.13",
    "expo-sharing": "~55.0.14",
    "expo-speech": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.20",
    "expo-web-browser": "~55.0.10",
    "firebase": "^12.11.0",
    "i18n-js": "^4.5.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-maps": "1.27.2",
    "react-native-pager-view": "8.0.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-tab-view": "^4.3.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
